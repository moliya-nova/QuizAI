.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 140rpx;
  z-index: 999;
}

.tab-bar-bg {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100%;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}

.tab-bar-content {
  position: relative;
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 100%;
  padding-bottom: 20rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 100%;
  position: relative;
  z-index: 2;
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 6rpx;
}

.tab-text {
  font-size: 22rpx;
  color: #9CA3AF;
  font-weight: 500;
}

.tab-text.active {
  color: #2B68FF;
  font-weight: 600;
}

/* 中间 AI 按钮 */
.center-item {
  position: relative;
  margin-top: -40rpx;
}

.center-btn {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.4);
  margin-bottom: 8rpx;
  transition: transform 0.2s ease;
}

.center-btn:active {
  transform: scale(0.92);
}

.center-icon {
  display: flex;
  align-items: center;
  justify-content: center;
}

.ai-text {
  font-size: 36rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: 2rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.center-text {
  color: #764ba2;
  font-weight: 600;
}
