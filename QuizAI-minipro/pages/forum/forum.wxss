page {
  background-color: #F7F9FC;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
}

.page-container {
  height: 100vh;
  box-sizing: border-box;
  position: relative;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.top-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 400rpx;
  background: linear-gradient(180deg, #E0E7FF 0%, #F7F9FC 100%);
  z-index: -1;
}

.custom-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 100rpx 30rpx 20rpx 30rpx;
  font-size: 34rpx;
  font-weight: bold;
  color: #111827;
  flex-shrink: 0;
}

.nav-back {
  font-size: 40rpx;
  width: 60rpx;
  color: #374151;
}

.nav-placeholder {
  width: 60rpx;
}

.main-scroll {
  flex: 1;
  height: 0;
  width: 100%;
}

/* 类型筛选 */
.type-tabs {
  display: flex;
  padding: 0 40rpx;
  margin-bottom: 24rpx;
  gap: 20rpx;
}

.tab-item {
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #6B7280;
  background: #FFF;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  transition: all 0.2s;
}

.tab-item.active {
  background: #2B68FF;
  color: #FFF;
  box-shadow: 0 4rpx 12rpx rgba(43, 104, 255, 0.3);
}

/* 搜索框 */
.search-bar {
  padding: 0 40rpx;
  margin-bottom: 30rpx;
}

.search-input {
  background: #FFF;
  border-radius: 28rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

/* 帖子列表 */
.post-list {
  padding: 0 40rpx;
}

.post-card {
  background: #FFF;
  border-radius: 32rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.03);
  transition: transform 0.2s;
  border-left: 8rpx solid transparent;
}

.post-card:active {
  transform: scale(0.98);
}

.post-card.help-card {
  border-left-color: #F59E0B;
  background: linear-gradient(135deg, #FFFBEB 0%, #FFF 40%);
}

.post-card.normal-card {
  border-left-color: #3B82F6;
}

.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.post-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #E5E7EB;
  margin-right: 16rpx;
}

.post-user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.post-nickname {
  font-size: 26rpx;
  font-weight: 600;
  color: #111827;
}

.post-time {
  font-size: 22rpx;
  color: #9CA3AF;
}

.post-type-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.post-type-badge.normal {
  background: #EFF6FF;
  color: #2563EB;
  border: 2rpx solid #BFDBFE;
}

.post-type-badge.help {
  background: #FEF3C7;
  color: #D97706;
  border: 2rpx solid #FDE68A;
}

.post-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.post-content-preview {
  font-size: 26rpx;
  color: #6B7280;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  line-height: 1.6;
}

.post-media-hint {
  display: flex;
  gap: 20rpx;
  margin-bottom: 12rpx;
}

.media-count {
  font-size: 22rpx;
  color: #6B7280;
}

.post-question-hint {
  background: #FFF7ED;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
  font-size: 24rpx;
}

.hint-label {
  color: #D97706;
  font-weight: 600;
  margin-right: 8rpx;
}

.hint-text {
  color: #92400E;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.post-stats {
  display: flex;
  gap: 32rpx;
}

.stat-item {
  font-size: 24rpx;
  color: #9CA3AF;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #9CA3AF;
}

.loading-more, .no-more {
  text-align: center;
  padding: 30rpx 0;
  font-size: 24rpx;
  color: #9CA3AF;
}

/* 悬浮按钮 */
.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 180rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2B68FF, #1E3A8A);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(43, 104, 255, 0.4);
  z-index: 100;
  transition: transform 0.2s;
}

.fab-btn:active {
  transform: scale(0.9);
}

.fab-icon {
  font-size: 48rpx;
  color: #FFF;
  font-weight: 300;
}

.my-btn {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #FFF;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
  z-index: 100;
}

.my-icon {
  font-size: 40rpx;
}
