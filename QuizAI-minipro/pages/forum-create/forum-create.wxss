page {
  background-color: #F7F9FC;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
}

.page-container {
  height: 100vh;
  box-sizing: border-box;
  position: relative;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.top-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 400rpx;
  background: linear-gradient(180deg, #E0E7FF 0%, #F7F9FC 100%);
  z-index: -1;
}

.custom-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 100rpx 30rpx 20rpx 30rpx;
  font-size: 34rpx;
  font-weight: bold;
  color: #111827;
  flex-shrink: 0;
}

.nav-back {
  font-size: 40rpx;
  width: 60rpx;
  color: #374151;
}

.nav-placeholder {
  width: 60rpx;
}

.main-scroll {
  flex: 1;
  height: 0;
  width: 100%;
}

/* 表单区域 */
.form-section {
  padding: 0 40rpx;
  margin-bottom: 36rpx;
}

.section-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 16rpx;
}

/* 类型切换 */
.type-toggle {
  display: flex;
  gap: 20rpx;
}

.type-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 0;
  background: #FFF;
  border-radius: 24rpx;
  border: 4rpx solid transparent;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  transition: all 0.2s;
}

.type-option.active {
  border-color: #2B68FF;
  background: #F0F5FF;
  box-shadow: 0 4rpx 16rpx rgba(43, 104, 255, 0.15);
}

.type-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.type-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
}

.type-option.active .type-name {
  color: #2B68FF;
}

/* 匿名发帖 */
.anonymous-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #FFF;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.anonymous-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.anonymous-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.anonymous-preview {
  font-size: 24rpx;
  color: #9CA3AF;
}

.anonymous-toggle {
  width: 96rpx;
  height: 52rpx;
  border-radius: 26rpx;
  background: #E5E7EB;
  position: relative;
  transition: background 0.25s;
}

.anonymous-toggle.active {
  background: #2B68FF;
}

.toggle-dot {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #FFF;
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.15);
  transition: transform 0.25s;
}

.anonymous-toggle.active .toggle-dot {
  transform: translateX(44rpx);
}

/* 题目选择 */
.question-scroll {
  width: 100%;
  white-space: nowrap;
}

.question-track {
  display: inline-flex;
  padding-bottom: 16rpx;
  gap: 16rpx;
}

.question-item {
  display: inline-flex;
  flex-direction: column;
  width: 400rpx;
  background: #FFF;
  border-radius: 24rpx;
  padding: 24rpx;
  border: 4rpx solid transparent;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  transition: all 0.2s;
}

.question-item.active {
  border-color: #2B68FF;
  background: #F0F5FF;
}

.q-subject {
  font-size: 22rpx;
  color: #6B7280;
  margin-bottom: 8rpx;
}

.q-content {
  font-size: 26rpx;
  color: #111827;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
  line-height: 1.5;
  white-space: normal;
}

.empty-question {
  padding: 40rpx;
  color: #9CA3AF;
  font-size: 26rpx;
}

/* 输入框 */
.input-wrapper {
  position: relative;
}

.title-input {
  background: #FFF;
  border-radius: 24rpx;
  padding: 20rpx 32rpx;
  font-size: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.char-count {
  position: absolute;
  right: 24rpx;
  bottom: 20rpx;
  font-size: 22rpx;
  color: #9CA3AF;
}

.textarea-wrapper {
  background: #FFF;
  border-radius: 24rpx;
  padding: 20rpx 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.content-textarea {
  width: 100%;
  min-height: 300rpx;
  font-size: 30rpx;
  line-height: 1.8;
}

/* 媒体上传 */
.media-picker {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.media-preview-item {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  background: #F3F4F6;
}

.media-thumb {
  width: 100%;
  height: 100%;
}

.media-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}

.media-overlay.success {
  background: rgba(34, 197, 94, 0.5);
}

.media-loading {
  color: #FFF;
  font-size: 22rpx;
}

.media-done {
  color: #FFF;
  font-size: 40rpx;
  font-weight: bold;
}

.media-remove {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #FFF;
  font-size: 24rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.media-add-btn {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  background: #F3F4F6;
  border: 2rpx dashed #D1D5DB;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.add-icon {
  font-size: 48rpx;
}

.add-text {
  font-size: 22rpx;
  color: #6B7280;
}

.media-hint {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #9CA3AF;
}

/* 底部提交按钮 */
.bottom-action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 30rpx 40rpx 60rpx 40rpx;
  background: linear-gradient(to top, rgba(247, 249, 252, 1) 60%, rgba(247, 249, 252, 0));
  box-sizing: border-box;
}

.submit-btn {
  width: 100% !important;
  height: 110rpx;
  line-height: 110rpx;
  background-color: #111827;
  color: #FFF;
  border-radius: 55rpx;
  font-size: 34rpx;
  font-weight: bold;
  box-shadow: 0 16rpx 32rpx rgba(17, 24, 39, 0.2);
  transition: transform 0.1s;
}

.submit-btn:active {
  transform: scale(0.96);
}

.submit-btn.disabled {
  background-color: #9CA3AF;
}

/* 草稿提示 */
.draft-banner {
  margin: 0 40rpx 24rpx;
  padding: 20rpx 24rpx;
  background: #FFF7ED;
  border-radius: 16rpx;
  border: 2rpx solid #FDE68A;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.draft-text {
  font-size: 26rpx;
  color: #D97706;
}

.draft-actions {
  display: flex;
  gap: 16rpx;
}

.draft-btn {
  padding: 8rpx 24rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.draft-btn.restore {
  background: #D97706;
  color: #FFF;
}

.draft-btn.discard {
  background: transparent;
  color: #9CA3AF;
  border: 2rpx solid #D1D5DB;
}

/* 内容字数统计 */
.textarea-wrapper {
  position: relative;
}

.content-count {
  position: absolute;
  right: 24rpx;
  bottom: 20rpx;
  font-size: 22rpx;
  color: #9CA3AF;
}

.char-count.warning,
.content-count.warning {
  color: #EF4444;
}
