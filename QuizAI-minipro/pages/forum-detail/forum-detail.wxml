<view class="page-container">
  <view class="top-bg"></view>
  <view class="custom-nav">
    <view class="nav-back" bindtap="goBack">←</view>
    <view class="nav-title">帖子详情</view>
    <view class="nav-placeholder"></view>
  </view>

  <scroll-view scroll-y class="main-scroll" show-scrollbar="false" enhanced="true">
    <view wx:if="{{loading}}" class="loading-state">
      <text>加载中...</text>
    </view>

    <view wx:if="{{post && !loading}}" class="content-area">
      <!-- 帖子状态提示 -->
      <view wx:if="{{post.status === 3}}" class="status-banner closed">
        <text>该帖子已被下架</text>
      </view>
      <view wx:elif="{{post.status === 2}}" class="status-banner rejected">
        <text>审核未通过</text>
        <text wx:if="{{post.rejectReason}}" class="reject-detail">: {{post.rejectReason}}</text>
      </view>
      <view wx:elif="{{post.status === 0}}" class="status-banner pending">
        <text>审核中</text>
      </view>

      <!-- 帖子详情 -->
      <view class="post-detail-card {{post.type === 1 ? 'help-card' : 'normal-card'}}">
        <view class="post-header">
          <image class="post-avatar" src="{{post.avatar || '/assets/logo/avatar.png'}}" mode="aspectFill"></image>
          <view class="post-user-info">
            <text class="post-nickname">{{post.nickname || '匿名用户'}}</text>
            <text class="post-time">{{post.createTimeFormatted}}</text>
          </view>
          <view wx:if="{{post.type === 1}}" class="post-type-badge help">🙋 求助帖</view>
          <view wx:else class="post-type-badge normal">📝 普通帖</view>
        </view>
        <view class="post-title">{{post.title}}</view>
        <view class="post-content">{{post.content}}</view>

        <!-- 帖子图片 -->
        <view wx:if="{{post.imageList && post.imageList.length > 0}}" class="post-media-section">
          <view class="image-grid {{post.imageList.length === 1 ? 'single' : ''}}">
            <image wx:for="{{post.imageList}}" wx:key="*this" class="post-image" src="{{item}}" mode="aspectFill" bindtap="previewImage" data-urls="{{post.imageList}}" data-current="{{item}}" />
          </view>
        </view>

        <!-- 帖子视频 -->
        <view wx:if="{{post.videoList && post.videoList.length > 0}}" class="post-media-section">
          <video wx:for="{{post.videoList}}" wx:key="*this" class="post-video" src="{{item}}" controls="{{true}}" show-fullscreen-btn="{{true}}" show-play-btn="{{true}}" object-fit="contain" />
        </view>

        <!-- 求助帖关联题目 -->
        <view wx:if="{{post.type === 1 && post.questionContent}}" class="question-card" bindtap="goToHelpQuestion">
          <view class="question-label">📖 关联题目</view>
          <view class="question-text">{{post.questionContent}}</view>
          <view class="question-action">点击查看 →</view>
        </view>

        <!-- 浏览量 -->
        <view class="view-count">
          <text>👁 {{post.viewCount || 0}} 次浏览</text>
        </view>
      </view>

      <!-- 操作栏 -->
      <view wx:if="{{post.status === 1}}" class="action-bar">
        <view class="action-item {{post.liked ? 'active' : ''}}" bindtap="toggleLike">
          <text class="action-icon">{{post.liked ? '❤️' : '🤍'}}</text>
          <text class="action-text">{{post.likeCount || 0}}</text>
        </view>
        <view class="action-item {{post.favorited ? 'active' : ''}}" bindtap="toggleFavorite">
          <text class="action-icon">{{post.favorited ? '⭐' : '☆'}}</text>
          <text class="action-text">{{post.favoriteCount || 0}}</text>
        </view>
        <view class="action-item" bindtap="reportPost">
          <text class="action-icon">🚩</text>
          <text class="action-text">举报</text>
        </view>
        <view class="action-item" bindtap="deletePost">
          <text class="action-icon">🗑️</text>
          <text class="action-text">删除</text>
        </view>
      </view>

      <!-- 评论区 -->
      <view class="comment-section">
        <view class="section-title">评论 ({{comments.length}})</view>
        <view wx:if="{{comments.length === 0}}" class="empty-comment">
          <text>暂无评论，快来抢沙发吧~</text>
        </view>
        <view wx:for="{{comments}}" wx:key="id" class="comment-item">
          <image class="comment-avatar" src="{{item.avatar || '/assets/logo/avatar.png'}}" mode="aspectFill"></image>
          <view class="comment-body">
            <view class="comment-header">
              <text class="comment-nickname">{{item.nickname || '匿名用户'}}</text>
              <text class="comment-time">{{item.createTimeFormatted}}</text>
            </view>
            <view wx:if="{{item.replyToNickname}}" class="reply-indicator">
              回复 <text class="reply-name">{{item.replyToNickname}}</text>
            </view>
            <view class="comment-content {{expandedMap[item.id] ? '' : 'comment-folded'}}">{{item.content}}</view>
            <view wx:if="{{item.content.length > 50}}" class="comment-toggle" data-id="{{item.id}}" catchtap="toggleExpand">
              <text>{{expandedMap[item.id] ? '收起' : '展开'}}</text>
            </view>
            <!-- 评论图片 -->
            <view wx:if="{{item.imageList && item.imageList.length > 0}}" class="comment-images">
              <image wx:for="{{item.imageList}}" wx:for-item="imgUrl" wx:key="*this" class="comment-image" src="{{imgUrl}}" mode="aspectFill" bindtap="previewImage" data-urls="{{item.imageList}}" data-current="{{imgUrl}}" />
            </view>
            <!-- 评论操作 -->
            <view class="comment-actions">
              <view class="comment-action-btn" bindtap="replyToComment" data-commentid="{{item.id}}" data-userid="{{item.userId}}" data-nickname="{{item.nickname}}">回复</view>
              <view class="comment-action-btn delete" catchtap="deleteComment" data-commentid="{{item.id}}">删除</view>
            </view>
          </view>
        </view>
      </view>

      <view style="height: 200rpx;"></view>
    </view>
  </scroll-view>

  <!-- 底部评论输入栏 -->
  <view wx:if="{{post.status === 1}}" class="comment-input-bar">
    <view wx:if="{{replyTo}}" class="reply-indicator-bar">
      <text>回复 {{replyTo.nickname}}</text>
      <text class="cancel-reply" bindtap="cancelReply">取消</text>
    </view>
    <!-- 评论图片预览 -->
    <view wx:if="{{commentImages.length > 0}}" class="comment-images-preview">
      <view wx:for="{{commentImages}}" wx:key="tempFilePath" class="comment-img-item">
        <image class="comment-img-thumb" src="{{item.tempFilePath}}" mode="aspectFill" />
        <view class="comment-img-remove" catchtap="removeCommentImage" data-index="{{index}}">✕</view>
      </view>
    </view>
    <view class="input-row">
      <view class="comment-img-btn" bindtap="chooseCommentImage">🖼</view>
      <input class="comment-input" placeholder="{{replyTo ? '回复 ' + replyTo.nickname + '...' : '写评论...'}}" value="{{commentText}}" bindinput="onCommentInput" bindconfirm="submitComment" />
      <view class="send-btn {{submitLoading ? 'disabled' : ''}}" bindtap="submitComment">{{submitLoading ? '发送中' : '发送'}}</view>
    </view>
  </view>
</view>
