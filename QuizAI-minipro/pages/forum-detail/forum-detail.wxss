page {
  background-color: #F7F9FC;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
}

.page-container {
  height: 100vh;
  box-sizing: border-box;
  position: relative;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.top-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 400rpx;
  background: linear-gradient(180deg, #E0E7FF 0%, #F7F9FC 100%);
  z-index: -1;
}

.custom-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 100rpx 30rpx 20rpx 30rpx;
  font-size: 34rpx;
  font-weight: bold;
  color: #111827;
  flex-shrink: 0;
}

.nav-back {
  font-size: 40rpx;
  width: 60rpx;
  color: #374151;
}

.nav-placeholder {
  width: 60rpx;
}

.main-scroll {
  flex: 1;
  height: 0;
  width: 100%;
}

.loading-state {
  text-align: center;
  padding: 120rpx 0;
  color: #9CA3AF;
  font-size: 28rpx;
}

.content-area {
  padding: 0 40rpx;
}

/* 状态提示横幅 */
.status-banner {
  padding: 20rpx 28rpx;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.status-banner.closed {
  background: #FEF2F2;
  color: #DC2626;
  border: 2rpx solid #FECACA;
}

.status-banner.rejected {
  background: #FFF7ED;
  color: #D97706;
  border: 2rpx solid #FED7AA;
}

.status-banner.pending {
  background: #EFF6FF;
  color: #2563EB;
  border: 2rpx solid #BFDBFE;
}

.reject-detail {
  font-weight: 400;
  color: #92400E;
}

/* 帖子详情卡片 */
.post-detail-card {
  background: #FFF;
  border-radius: 32rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.03);
  border-left: 8rpx solid transparent;
}

.post-detail-card.help-card {
  border-left-color: #F59E0B;
  background: linear-gradient(135deg, #FFFBEB 0%, #FFF 40%);
}

.post-detail-card.normal-card {
  border-left-color: #3B82F6;
}

.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.post-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #E5E7EB;
  margin-right: 20rpx;
}

.post-user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.post-nickname {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.post-time {
  font-size: 22rpx;
  color: #9CA3AF;
}

.post-type-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.post-type-badge.normal {
  background: #EFF6FF;
  color: #2563EB;
  border: 2rpx solid #BFDBFE;
}

.post-type-badge.help {
  background: #FEF3C7;
  color: #D97706;
  border: 2rpx solid #FDE68A;
}

.post-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.post-content {
  font-size: 30rpx;
  color: #374151;
  line-height: 1.8;
  white-space: pre-wrap;
}

/* 求助题目标卡 */
.question-card {
  margin-top: 24rpx;
  background: #FFF7ED;
  border-radius: 24rpx;
  padding: 24rpx;
  border: 2rpx solid #FDE68A;
}

.question-label {
  font-size: 24rpx;
  color: #D97706;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.question-text {
  font-size: 28rpx;
  color: #92400E;
  line-height: 1.6;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

.question-action {
  font-size: 24rpx;
  color: #D97706;
  font-weight: 600;
  text-align: right;
}

/* 操作栏 */
.action-bar {
  display: flex;
  background: #FFF;
  border-radius: 28rpx;
  padding: 24rpx 0;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}

.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  transition: transform 0.2s;
}

.action-item:active {
  transform: scale(0.9);
}

.action-item.active .action-text {
  color: #2B68FF;
}

.action-icon {
  font-size: 40rpx;
}

.action-text {
  font-size: 24rpx;
  color: #6B7280;
}

/* 评论区 */
.comment-section {
  background: #FFF;
  border-radius: 32rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 24rpx;
}

.empty-comment {
  text-align: center;
  padding: 60rpx 0;
  font-size: 26rpx;
  color: #9CA3AF;
}

.comment-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #F3F4F6;
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #E5E7EB;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.comment-body {
  flex: 1;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.comment-nickname {
  font-size: 24rpx;
  font-weight: 600;
  color: #374151;
}

.comment-time {
  font-size: 20rpx;
  color: #9CA3AF;
}

.reply-indicator {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-bottom: 6rpx;
}

.reply-name {
  color: #2B68FF;
}

.comment-content {
  font-size: 28rpx;
  color: #111827;
  line-height: 1.6;
}

.comment-content.comment-folded {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.comment-toggle {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #2B68FF;
  font-weight: 500;
}

/* 帖子媒体 */
.post-media-section {
  margin-top: 24rpx;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.image-grid.single .post-image {
  width: 400rpx;
  height: 400rpx;
  border-radius: 16rpx;
}

.post-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  background: #F3F4F6;
}

.post-video {
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  margin-top: 12rpx;
}

/* 评论图片 */
.comment-images {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.comment-image {
  width: 150rpx;
  height: 150rpx;
  border-radius: 8rpx;
  background: #F3F4F6;
}

/* 底部评论输入栏 */
.comment-input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background: #FFF;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
  z-index: 100;
}

.reply-indicator-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 30rpx;
  background: #F3F4F6;
  font-size: 24rpx;
  color: #6B7280;
}

.cancel-reply {
  color: #EF4444;
  font-weight: 600;
}

.input-row {
  display: flex;
  align-items: center;
  padding: 16rpx 30rpx 40rpx 30rpx;
  gap: 16rpx;
}

.comment-input {
  flex: 1;
  background: #F3F4F6;
  border-radius: 32rpx;
  padding: 16rpx 28rpx;
  font-size: 28rpx;
}

.send-btn {
  background: #2B68FF;
  color: #FFF;
  padding: 16rpx 32rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: transform 0.2s;
}

.send-btn:active {
  transform: scale(0.95);
}

/* 评论图片预览 */
.comment-images-preview {
  display: flex;
  padding: 12rpx 30rpx 0;
  gap: 12rpx;
}

.comment-img-item {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
}

.comment-img-thumb {
  width: 100%;
  height: 100%;
}

.comment-img-remove {
  position: absolute;
  top: 0;
  right: 0;
  width: 32rpx;
  height: 32rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #FFF;
  font-size: 20rpx;
  border-radius: 0 0 0 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.comment-img-btn {
  font-size: 40rpx;
  padding: 0 8rpx;
  flex-shrink: 0;
}

/* 浏览量 */
.view-count {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #F3F4F6;
  font-size: 24rpx;
  color: #9CA3AF;
}

/* 评论操作 */
.comment-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 12rpx;
}

.comment-action-btn {
  font-size: 22rpx;
  color: #6B7280;
  padding: 4rpx 0;
}

.comment-action-btn.delete {
  color: #EF4444;
}

.send-btn.disabled {
  opacity: 0.5;
  pointer-events: none;
}
