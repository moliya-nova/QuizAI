<view class="page-container">
  <view class="top-bg"></view>

  <view class="custom-nav">
    <view class="nav-title">个人中心</view>
  </view>

  <scroll-view scroll-y class="main-scroll" show-scrollbar="false" enhanced="true">
    <!-- 用户信息头部 -->
    <view class="header-section">
      <view class="user-info">
        <image class="avatar" src="{{userInfo.avatar || '/assets/logo/avatar.png'}}" mode="aspectFill"></image>
        <view class="info-text">
          <text class="nickname">{{userInfo.nickname || '未登录用户'}}</text>
          <text class="username">账号：{{userInfo.username || '请先登录'}}</text>
        </view>
      </view>
    </view>

    <!-- 数据概览卡片 (并排风格) -->
    <view class="stats-grid">
      <view class="stat-card blue-card">
        <view class="stat-content">
          <text class="stat-value">{{totalPractice || 0}}</text>
          <text class="stat-label">累计练习</text>
        </view>
        <view class="stat-icon-bg">🔥</view>
      </view>
      
      <view class="stat-card green-card">
        <view class="stat-content">
          <text class="stat-value">{{accuracy || '0.0'}}%</text>
          <text class="stat-label">平均正确率</text>
        </view>
        <view class="stat-icon-bg">🎯</view>
      </view>
    </view>

    <!-- 功能菜单 -->
    <view class="menu-section">
      <view class="menu-item" bindtap="showTrendModal">
        <view class="menu-left">
          <text class="menu-icon">📊</text>
          <text class="menu-text">近期正确率</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" bindtap="goToWrongPage">
        <view class="menu-left">
          <text class="menu-icon">📓</text>
          <text class="menu-text">我的错题本</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" bindtap="goToHistory">
        <view class="menu-left">
          <text class="menu-icon">📋</text>
          <text class="menu-text">练习记录</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" bindtap="showDevToast">
        <view class="menu-left">
          <text class="menu-icon">💬</text>
          <text class="menu-text">AI 智能对话</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" bindtap="goToUserInfo">
        <view class="menu-left">
          <text class="menu-icon">👤</text>
          <text class="menu-text">个人信息</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <!-- 退出登录 -->
    <view class="logout-section">
      <button class="logout-btn" bindtap="logout">退出登录</button>
    </view>
    
    <view style="height: 100rpx;"></view>
  </scroll-view>

  <!-- 近期正确率弹窗 -->
  <view class="modal-mask" wx:if="{{isTrendModalVisible}}" bindtap="closeTrendModal">
    <view class="modal-content" catchtap="preventBubble">
      <view class="modal-header">
        <text class="modal-title">近期正确率</text>
        <text class="modal-close" bindtap="closeTrendModal">×</text>
      </view>
      <view class="chart-box">
        <view class="bar-container">
          <view class="bar-wrapper" wx:for="{{trendData}}" wx:key="index">
            <view class="bar-value {{item < 60 ? 'text-danger' : (item >= 90 ? 'text-success' : 'text-primary')}}">{{item}}</view>
            <view class="bar-track">
              <view class="bar-fill {{item < 60 ? 'bg-danger' : (item >= 90 ? 'bg-success' : 'bg-primary')}}" style="height: {{item}}%;"></view>
            </view>
            <view class="bar-dot"></view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
