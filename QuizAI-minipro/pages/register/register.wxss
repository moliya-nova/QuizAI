/* 复用 login.wxss 的样式 */
page {
  background-color: #F7F9FC;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, sans-serif;
}

.page-container {
  min-height: 100vh;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 0rpx; /* 注册项多，稍微调高一点 */
  padding-bottom: 60rpx;
}

/* 顶部装饰背景 */
.top-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 480rpx;
  background: linear-gradient(180deg, #E0E7FF 0%, #F7F9FC 100%);
  z-index: -1;
}

/* 自定义导航栏 */
.custom-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  box-sizing: border-box;
  padding: 100rpx 40rpx 20rpx 40rpx;
  font-size: 34rpx;
  font-weight: bold;
  color: #111827;
  margin-bottom: 40rpx;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: transparent;
}

.nav-icon {
  font-size: 36rpx;
}

.nav-placeholder {
  width: 60rpx;
}

/* 头部样式 */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.logo-box {
  width: 140rpx;
  height: 140rpx;
  background-color: #FFF;
  border-radius: 40rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 16rpx 40rpx rgba(43, 104, 255, 0.1);
  margin-bottom: 30rpx;
}

.logo-icon {
  font-size: 70rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 800;
  color: #111827;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #6B7280;
}

/* 表单卡片 */
.form-card {
  width: 86%;
  background-color: #FFF;
  border-radius: 40rpx;
  padding: 60rpx 50rpx;
  box-shadow: 0 16rpx 60rpx rgba(0, 0, 0, 0.04);
  box-sizing: border-box;
}

.input-group {
  display: flex;
  align-items: center;
  background-color: #F3F4F6;
  border-radius: 24rpx;
  padding: 0 32rpx;
  height: 110rpx;
  margin-bottom: 30rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.input-group:focus-within {
  background-color: #FFF;
  border-color: #2B68FF;
  box-shadow: 0 4rpx 16rpx rgba(43, 104, 255, 0.1);
}

.input-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  opacity: 0.6;
}

.input {
  flex: 1;
  height: 100%;
  font-size: 32rpx;
  color: #111827;
}

.placeholder-style {
  color: #9CA3AF;
  font-size: 30rpx;
}

/* 主按钮 */
.primary-btn {
  width: 100% !important;
  height: 110rpx;
  line-height: 110rpx;
  background-color: #111827;
  color: #FFF;
  border-radius: 30rpx;
  font-size: 34rpx;
  font-weight: bold;
  box-shadow: 0 16rpx 32rpx rgba(17, 24, 39, 0.15);
  margin-top: 30rpx;
  margin-bottom: 40rpx;
  transition: transform 0.1s;
}

.primary-btn:active {
  transform: scale(0.96);
}

/* 底部链接 */
.action-links {
  display: flex;
  justify-content: center;
  width: 100%;
}

.link-text {
  font-size: 28rpx;
  color: #2B68FF;
  font-weight: 600;
  padding: 20rpx;
}
