<view class="page-container">
  <view class="top-bg"></view>
  <view class="custom-nav">
    <view class="nav-title">首页</view>
  </view>

  <scroll-view scroll-y class="main-scroll" show-scrollbar="false" enhanced="true">
    <!-- 头部：欢迎语与头像 -->
    <view class="header">
      <view class="header-text">
        <text class="title">Hello, {{userInfo.nickname || userInfo.username || '同学'}} 👋</text>
        <text class="subtitle">今天想提升哪方面的技能？</text>
      </view>
      <image class="avatar" src="{{userInfo.avatar || '/assets/logo/avatar.png'}}" mode="aspectFill"></image>
    </view>

    <!-- 排行榜 -->
    <view class="section leaderboard-section">
      <view class="section-header">刷题达人榜</view>
      <view class="leaderboard-card">
        <view class="leaderboard-item" wx:for="{{leaderboard}}" wx:key="userId">
          <view class="rank-badge rank-{{index + 1}}">{{index + 1}}</view>
          <image class="lb-avatar" src="{{item.avatar || '/assets/logo/avatar.png'}}" mode="aspectFill"></image>
          <view class="lb-info">
            <text class="lb-name">{{item.name}}</text>
            <text class="lb-score">{{item.totalPractice}} 题</text>
          </view>
        </view>
        <view class="empty-lb" wx:if="{{!leaderboard || leaderboard.length === 0}}">
          <text>暂无数据，快来做第一个刷题达人！</text>
        </view>
      </view>
    </view>

    <!-- 错题本入口 -->
    <view class="wrong-entry" bindtap="goToWrongPage">
      <view class="wrong-left">
        <text class="wrong-icon">📓</text>
        <view class="wrong-text">
          <text class="wrong-title">我的错题本</text>
          <text class="wrong-desc">复习做错的题目，巩固知识</text>
        </view>
      </view>
      <view class="wrong-right">
        <text class="wrong-arrow">→</text>
      </view>
    </view>

    <!-- 科目选择 (横向滑动卡片) -->
    <view class="section">
      <view class="section-header">选择练习科目</view>
      <scroll-view scroll-x class="subject-scroll" show-scrollbar="false" enhanced="true">
        <view class="subject-track">
          <view 
            wx:for="{{subjectList}}" 
            wx:key="name"
            class="subject-item {{selectedSubject === item.name ? 'active' : ''}}"
            bindtap="onSelectSubject"
            data-subject="{{item.name}}"
          >
            <view class="sub-icon">{{item.icon}}</view>
            <text class="sub-name">{{item.name}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 题数选择 (苹果风分段控制器) -->
    <view class="section">
      <view class="section-header">题目数量</view>
      <view class="segmented-control">
        <view 
          wx:for="{{counts}}" 
          wx:key="*this"
          class="segment-item {{selectedCount === item ? 'active' : ''}}"
          bindtap="onSelectCount"
          data-count="{{item}}"
        >
          {{item}} 题
        </view>
      </view>
    </view>
    
    <!-- 底部留白 -->
    <view style="height: 200rpx;"></view>
  </scroll-view>

  <!-- 底部悬浮操作栏 -->
  <view class="bottom-action-bar">
    <button class="start-btn" bindtap="startPractice">
      开始练习 <text class="btn-arrow">→</text>
    </button>
  </view>
</view>
