page {
  background-color: #F7F9FC;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
}

.page-container {
  height: 100vh;
  box-sizing: border-box;
  position: relative;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 顶部装饰背景 */
.top-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 400rpx;
  background: linear-gradient(180deg, #E0E7FF 0%, #F7F9FC 100%);
  z-index: -1;
}

/* 自定义导航栏 */
.custom-nav {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0rpx 20rpx 0rpx; /* 适配状态栏 */
  font-size: 34rpx;
  font-weight: bold;
  color: #111827;
  margin-bottom: 20rpx;
  flex-shrink: 0;
}

/* 主体滚动区 */
.main-scroll {
  flex: 1;
  height: 0;
  width: 100%;
}

/* 头部 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 60rpx;
  padding: 0 40rpx;
}

.header-text {
  display: flex;
  flex-direction: column;
}

.title {
  font-size: 44rpx;
  font-weight: 800;
  color: #111827;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #6B7280;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: #E5E7EB;
  border: 4rpx solid #FFF;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

/* 排行榜 */
.leaderboard-section {
  margin-bottom: 60rpx;
  padding: 0 40rpx;
}

.leaderboard-card {
  background-color: #FFF;
  border-radius: 32rpx;
  padding: 30rpx 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.03);
}

.leaderboard-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #F3F4F6;
}

.leaderboard-item:last-child {
  border-bottom: none;
}

.rank-badge {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 24rpx;
  font-weight: bold;
  color: #FFF;
  background-color: #D1D5DB;
  margin-right: 24rpx;
}

.rank-1 { background-color: #FBBF24; box-shadow: 0 4rpx 8rpx rgba(251, 191, 36, 0.3); }
.rank-2 { background-color: #9CA3AF; box-shadow: 0 4rpx 8rpx rgba(156, 163, 175, 0.3); }
.rank-3 { background-color: #D97706; box-shadow: 0 4rpx 8rpx rgba(217, 119, 6, 0.3); }

.lb-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #E5E7EB;
  margin-right: 24rpx;
}

.lb-info {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.lb-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.lb-score {
  font-size: 28rpx;
  font-weight: bold;
  color: #2B68FF;
}

.empty-lb {
  text-align: center;
  padding: 40rpx 0;
  font-size: 26rpx;
  color: #9CA3AF;
}

/* 错题本入口 */
.wrong-entry {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #FFF;
  border-radius: 32rpx;
  padding: 30rpx 40rpx;
  margin: 0 40rpx 60rpx 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.03);
  transition: transform 0.2s;
}

.wrong-entry:active {
  transform: scale(0.98);
  background-color: #F9FAFB;
}

.wrong-left {
  display: flex;
  align-items: center;
}

.wrong-icon {
  font-size: 60rpx;
  margin-right: 24rpx;
}

.wrong-text {
  display: flex;
  flex-direction: column;
}

.wrong-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #111827;
  margin-bottom: 4rpx;
}

.wrong-desc {
  font-size: 24rpx;
  color: #6B7280;
}

.wrong-right {
  width: 60rpx;
  height: 60rpx;
  background-color: #F3F4F6;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.wrong-arrow {
  color: #4B5563;
  font-weight: bold;
}

/* 通用 Section 样式 */
.section {
  margin-bottom: 60rpx;
  padding: 0 40rpx;
}

.section-header {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 24rpx;
}

/* 横向滑动科目选择 */
.subject-scroll {
  width: 100%;
  white-space: nowrap;
}

.subject-track {
  display: inline-flex;
  padding-bottom: 16rpx; /* 为阴影留空间 */
  padding-left: 4rpx;
  padding-right: 40rpx;
}

.subject-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #FFF;
  border-radius: 28rpx;
  padding: 32rpx 40rpx;
  margin-right: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.03);
  transition: all 0.2s ease;
  border: 4rpx solid transparent;
}

.subject-item:last-child {
  margin-right: 0;
}

.subject-item.active {
  background-color: #F0F5FF;
  border-color: #2B68FF;
  box-shadow: 0 8rpx 24rpx rgba(43, 104, 255, 0.15);
}

.sub-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.sub-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #4B5563;
}

.subject-item.active .sub-name {
  color: #2B68FF;
}

/* 苹果风分段控制器 (题目数量) */
.segmented-control {
  display: flex;
  background-color: #E5E7EB;
  border-radius: 20rpx;
  padding: 8rpx;
}

.segment-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  font-weight: 600;
  color: #6B7280;
  border-radius: 16rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.segment-item.active {
  background-color: #FFF;
  color: #111827;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}

/* 底部悬浮操作栏 */
.bottom-action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 30rpx 40rpx 60rpx 40rpx; /* 适配全面屏底部安全区 */
  background: linear-gradient(to top, rgba(247, 249, 252, 1) 60%, rgba(247, 249, 252, 0));
  box-sizing: border-box;
  pointer-events: none; /* 让背景点击穿透 */
}

.start-btn {
  pointer-events: auto; /* 按钮恢复点击 */
  width: 100% !important;
  height: 110rpx;
  line-height: 110rpx;
  background-color: #111827;
  color: #FFF;
  border-radius: 55rpx;
  font-size: 34rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 32rpx rgba(17, 24, 39, 0.2);
  transition: transform 0.1s;
}

.start-btn:active {
  transform: scale(0.96);
}

.btn-arrow {
  margin-left: 12rpx;
  font-weight: 400;
}
