page {
  background-color: #F7F9FC;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
}

.page-container {
  height: 100vh;
  box-sizing: border-box;
  position: relative;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.top-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 400rpx;
  background: linear-gradient(180deg, #E0E7FF 0%, #F7F9FC 100%);
  z-index: -1;
}

.custom-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 100rpx 30rpx 20rpx 30rpx;
  font-size: 34rpx;
  font-weight: bold;
  color: #111827;
  flex-shrink: 0;
}

.nav-back {
  font-size: 40rpx;
  width: 60rpx;
  color: #374151;
}

.nav-placeholder {
  width: 60rpx;
}

/* Tab 切换 */
.tab-bar {
  display: flex;
  padding: 0 40rpx;
  margin-bottom: 24rpx;
  gap: 0;
  flex-shrink: 0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  font-weight: 600;
  color: #6B7280;
  border-bottom: 4rpx solid transparent;
  transition: all 0.2s;
}

.tab-item.active {
  color: #2B68FF;
  border-bottom-color: #2B68FF;
}

.main-scroll {
  flex: 1;
  height: 0;
  width: 100%;
}

.list-area {
  padding: 0 40rpx;
}

/* 帖子卡片 */
.post-card {
  background: #FFF;
  border-radius: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
  overflow: hidden;
  border-left: 8rpx solid transparent;
}

.post-card.help-card {
  border-left-color: #F59E0B;
  background: linear-gradient(135deg, #FFFBEB 0%, #FFF 40%);
}

.post-card.normal-card {
  border-left-color: #3B82F6;
}

.post-type-badge {
  padding: 6rpx 14rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  flex-shrink: 0;
}

.post-type-badge.normal {
  background: #EFF6FF;
  color: #2563EB;
  border: 2rpx solid #BFDBFE;
}

.post-type-badge.help {
  background: #FEF3C7;
  color: #D97706;
  border: 2rpx solid #FDE68A;
}

.header-tags {
  display: flex;
  gap: 8rpx;
  flex-shrink: 0;
  align-items: center;
}

.card-content {
  padding: 28rpx;
}

.card-content:active {
  background: #F9FAFB;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
  flex: 1;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
  margin-right: 16rpx;
}

.status-badge {
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.status-0 {
  background: #FEF3C7;
  color: #D97706;
}

.status-1 {
  background: #D1FAE5;
  color: #059669;
}

.status-2 {
  background: #FEE2E2;
  color: #EF4444;
}

.status-3 {
  background: #F3F4F6;
  color: #6B7280;
}

.card-preview {
  font-size: 26rpx;
  color: #6B7280;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.reject-reason {
  font-size: 24rpx;
  color: #EF4444;
  background: #FEF2F2;
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-time {
  font-size: 22rpx;
  color: #9CA3AF;
}

.card-stats {
  display: flex;
  gap: 20rpx;
  font-size: 22rpx;
  color: #9CA3AF;
}

.card-actions {
  display: flex;
  justify-content: flex-end;
  padding: 0 28rpx 20rpx;
}

.delete-btn {
  padding: 8rpx 24rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #EF4444;
  background: #FEF2F2;
  transition: transform 0.2s;
}

.delete-btn:active {
  transform: scale(0.95);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #9CA3AF;
}

.loading-more, .no-more {
  text-align: center;
  padding: 30rpx 0;
  font-size: 24rpx;
  color: #9CA3AF;
}
