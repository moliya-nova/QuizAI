page {
  background-color: #F7F9FC;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, sans-serif;
}

.page-container {
  display: flex;
  flex-direction: column;
  position: relative;
  height: 100vh;
  overflow: hidden;
}

.top-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 400rpx;
  background: linear-gradient(180deg, #E0E7FF 0%, #F7F9FC 100%);
  z-index: -1;
}

.custom-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 100rpx 40rpx 20rpx 40rpx;
  flex-shrink: 0;
}

.nav-back {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: -20rpx;
}

.back-icon {
  font-size: 56rpx;
  color: #374151;
  font-weight: 300;
  line-height: 1;
}

.nav-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #111827;
}

.nav-placeholder {
  width: 80rpx;
}

.main-scroll {
  flex: 1;
  height: 0;
  width: 100%;
}

.scroll-inner {
  padding: 20rpx 40rpx 60rpx;
}

.loading-state {
  display: flex;
  justify-content: center;
  padding-top: 200rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #9CA3AF;
}

.summary-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
}

.summary-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.summary-subject {
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
}

.summary-accuracy {
  min-width: 100rpx;
  height: 56rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 20rpx;
}

.summary-accuracy.high {
  background-color: #D1FAE5;
}

.summary-accuracy.mid {
  background-color: #FEF3C7;
}

.summary-accuracy.low {
  background-color: #FEE2E2;
}

.summary-accuracy-text {
  font-size: 28rpx;
  font-weight: 700;
}

.summary-accuracy.high .summary-accuracy-text {
  color: #065F46;
}

.summary-accuracy.mid .summary-accuracy-text {
  color: #92400E;
}

.summary-accuracy.low .summary-accuracy-text {
  color: #991B1B;
}

.summary-date {
  font-size: 24rpx;
  color: #9CA3AF;
  display: block;
  margin-bottom: 24rpx;
}

.summary-stats {
  display: flex;
  justify-content: space-around;
  padding-top: 20rpx;
  border-top: 2rpx solid #F3F4F6;
}

.summary-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-stat-num {
  font-size: 40rpx;
  font-weight: 800;
  color: #374151;
}

.summary-stat-num.correct {
  color: #10B981;
}

.summary-stat-num.wrong {
  color: #EF4444;
}

.summary-stat-label {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 4rpx;
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.section-title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #374151;
}

.section-title-count {
  font-size: 24rpx;
  color: #9CA3AF;
}

.question-card {
  background-color: #FFF;
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.03);
}

.q-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.q-badge {
  font-size: 22rpx;
  font-weight: 700;
  padding: 6rpx 18rpx;
  border-radius: 12rpx;
}

.q-badge.badge-correct {
  background-color: #D1FAE5;
  color: #065F46;
}

.q-badge.badge-wrong {
  background-color: #FEE2E2;
  color: #991B1B;
}

.q-number {
  font-size: 24rpx;
  color: #9CA3AF;
  font-weight: 500;
}

.q-content {
  font-size: 32rpx;
  color: #111827;
  font-weight: 600;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.options-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-card {
  display: flex;
  align-items: center;
  background-color: #FFF;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  border: 3rpx solid #F3F4F6;
}

.opt-prefix {
  margin-right: 20rpx;
  flex-shrink: 0;
}

.opt-letter {
  width: 52rpx;
  height: 52rpx;
  background-color: #F3F4F6;
  color: #6B7280;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 800;
}

.opt-body {
  flex: 1;
}

.opt-text {
  font-size: 28rpx;
  color: #374151;
  line-height: 1.5;
  font-weight: 500;
}

.option-card.is-correct {
  background-color: #ECFDF5;
  border-color: #10B981;
}

.option-card.is-correct .opt-letter {
  background-color: #10B981;
  color: #FFF;
}

.option-card.is-correct .opt-text {
  color: #065F46;
}

.option-card.is-wrong {
  background-color: #FEF2F2;
  border-color: #EF4444;
}

.option-card.is-wrong .opt-letter {
  background-color: #EF4444;
  color: #FFF;
}

.option-card.is-wrong .opt-text {
  color: #991B1B;
}

.option-card.is-disabled {
  opacity: 0.6;
}

.answer-hint {
  margin-top: 20rpx;
  padding: 20rpx 24rpx;
  background-color: #FFFBEB;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
}

.hint-label {
  font-size: 26rpx;
  color: #92400E;
  font-weight: 500;
}

.hint-value {
  font-size: 28rpx;
  color: #D97706;
  font-weight: 800;
  margin-left: 8rpx;
}