page {
  background-color: #F7F9FC;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, sans-serif;
}

.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 88rpx 30rpx 20rpx;
  background: linear-gradient(180deg, #E0E7FF 0%, #F7F9FC 100%);
  flex-shrink: 0;
}

.nav-left,
.nav-right {
  width: 68rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(10px);
}

.nav-back-icon {
  font-size: 48rpx;
  color: #374151;
  font-weight: 300;
  line-height: 1;
}

.nav-action-icon {
  font-size: 40rpx;
  color: #374151;
}

.nav-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.title-icon {
  font-size: 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.title-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
}

/* 消息列表 */
.message-list {
  flex: 1;
  height: 0;
  width: 100%;
  padding: 0 24rpx;
  box-sizing: border-box;
}

/* 欢迎界面 */
.welcome-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx 40rpx;
}

.welcome-avatar {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.avatar-glow {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  opacity: 0.2;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 0.2; }
  50% { transform: scale(1.1); opacity: 0.3; }
}

.avatar-emoji {
  font-size: 64rpx;
  position: relative;
  z-index: 2;
}

.welcome-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 12rpx;
}

.welcome-desc {
  font-size: 26rpx;
  color: #6B7280;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 48rpx;
}

/* 快捷入口 */
.quick-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
}

.action-card {
  display: flex;
  align-items: center;
  padding: 22rpx 26rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
}

.action-card:active {
  transform: scale(0.98);
  background: #F9FAFB;
}

.action-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.action-text {
  font-size: 26rpx;
  color: #374151;
  font-weight: 500;
}

/* 消息行 */
.messages-wrapper {
  padding: 20rpx 0;
}

.message-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.user-row {
  justify-content: flex-end;
}

.ai-row {
  justify-content: flex-start;
}

/* 消息气泡 */
.message-bubble {
  max-width: 82%;
  padding: 18rpx 24rpx;
  border-radius: 24rpx;
  position: relative;
  word-wrap: break-word;
  word-break: break-all;
}

.user-bubble {
  background: linear-gradient(135deg, #3B82F6 0%, #2563EB 100%);
}

.ai-bubble {
  background: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  max-width: 100%;
  padding: 22rpx 28rpx;
}

.bubble-text {
  font-size: 26rpx;
  line-height: 1.6;
}

.user-bubble .bubble-text {
  color: #FFFFFF;
}

.ai-bubble .bubble-text {
  color: #1F2937;
  line-height: 1.8;
}

/* Markdown 渲染容器样式 (子元素样式通过 parseMarkdown 内联注入) */
.markdown-body {
  font-size: 26rpx;
  line-height: 1.9;
  color: #1F2937;
  word-wrap: break-word;
  word-break: break-all;
}

/* 打字指示器 */
.typing-indicator {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 0;
}

.typing-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #9CA3AF;
  animation: typingBounce 1.4s ease-in-out infinite;
}

.typing-dot:nth-child(2) {
  animation-delay: 0.2s;
}

.typing-dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes typingBounce {
  0%, 80%, 100% { transform: translateY(0); opacity: 0.4; }
  40% { transform: translateY(-8rpx); opacity: 1; }
}

/* 推荐问题 */
.suggestions-section {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 16rpx 0 32rpx;
}

.suggestion-item {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 22rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  border: 2rpx solid #E5E7EB;
  transition: all 0.2s ease;
}

.suggestion-item:active {
  background: #F3F4F6;
  border-color: #D1D5DB;
}

.suggestion-text {
  font-size: 24rpx;
  color: #374151;
  white-space: nowrap;
}

.bottom-spacer {
  height: 40rpx;
}

/* 停止按钮 */
.stop-btn-wrapper {
  display: flex;
  justify-content: center;
  padding: 16rpx 0;
  background: transparent;
}

.stop-btn {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 28rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  border: 2rpx solid #E5E7EB;
}

.stop-btn:active {
  background: #F9FAFB;
}

.stop-icon {
  width: 20rpx;
  height: 20rpx;
  background: #EF4444;
  border-radius: 4rpx;
}

.stop-text {
  font-size: 24rpx;
  color: #6B7280;
  font-weight: 500;
}

/* 输入区域 */
.input-area {
  padding: 16rpx 30rpx;
  padding-bottom: calc(170rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
  flex-shrink: 0;
}

.input-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #F3F4F6;
  border-radius: 36rpx;
  padding: 6rpx 6rpx 6rpx 24rpx;
}

.message-input {
  flex: 1;
  height: 68rpx;
  font-size: 26rpx;
  color: #1F2937;
}

.input-placeholder {
  color: #9CA3AF;
}

.send-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #D1D5DB;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.send-btn.active {
  background: linear-gradient(135deg, #3B82F6 0%, #2563EB 100%);
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.4);
}

.send-btn.active:active {
  transform: scale(0.92);
}

.send-icon {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 700;
}
