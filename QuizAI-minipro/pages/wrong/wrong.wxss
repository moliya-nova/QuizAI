/* 复用类似首页和练习页的基础样式 */
page {
  background-color: #F7F9FC;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, sans-serif;
  height: 100vh;
  overflow: hidden;
}

.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  position: relative;
}

.top-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 360rpx;
  background: linear-gradient(180deg, #E0E7FF 0%, #F7F9FC 100%);
  z-index: -1;
}

.custom-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 100rpx 40rpx 20rpx 40rpx;
  font-size: 34rpx;
  font-weight: bold;
  color: #111827;
  flex-shrink: 0;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #FFF;
  border-radius: 50%;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.nav-icon {
  font-size: 32rpx;
}

.nav-placeholder {
  width: 60rpx;
}

/* 科目过滤栏 */
.filter-section {
  padding: 20rpx 0 20rpx 40rpx;
}

.filter-scroll {
  width: 100%;
  white-space: nowrap;
}

.filter-track {
  display: inline-flex;
  padding-bottom: 20rpx; /* 留出阴影空间 */
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background-color: #FFF;
  color: #4B5563;
  border-radius: 40rpx;
  padding: 12rpx 36rpx;
  margin-right: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02);
  transition: all 0.2s ease;
  border: 2rpx solid transparent;
}

.filter-chip.active {
  background-color: #FEF2F2;
  color: #EF4444;
  border-color: #FCA5A5;
}

/* 列表区 */
.list-container {
  flex: 1;
  height: 0;
  width: 100%;
  padding: 0 40rpx;
  box-sizing: border-box;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-top: 160rpx;
}

.loading-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.pulse-animation {
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.1); opacity: 0.7; }
  100% { transform: scale(1); opacity: 1; }
}

.loading-text {
  color: #6B7280;
  font-size: 32rpx;
  font-weight: 500;
}

.back-btn {
  margin-top: 40rpx;
  background-color: #111827;
  color: #FFF;
  border-radius: 40rpx;
  padding: 0 60rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  font-weight: bold;
}

/* 错题卡片 */
.wrong-card {
  background-color: #FFF;
  border-radius: 32rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.03);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.subject-badge {
  background-color: #F3F4F6;
  color: #4B5563;
  font-size: 22rpx;
  font-weight: 700;
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
}

.remove-btn {
  color: #EF4444;
  font-size: 26rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  background-color: #FEF2F2;
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
  transition: transform 0.1s;
}

.remove-btn:active {
  transform: scale(0.95);
}

.remove-icon {
  margin-right: 8rpx;
  font-size: 24rpx;
}

.q-content {
  font-size: 32rpx;
  color: #111827;
  font-weight: 600;
  line-height: 1.6;
  margin-bottom: 30rpx;
}

.answer-box {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #F9FAFB;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
}

.correct-answer {
  display: flex;
  align-items: center;
}

.answer-label {
  font-size: 26rpx;
  color: #6B7280;
}

.answer-val {
  font-size: 32rpx;
  font-weight: 800;
  color: #10B981;
}

.toggle-analysis {
  font-size: 26rpx;
  color: #2B68FF;
  font-weight: bold;
  display: flex;
  align-items: center;
}

.arrow {
  margin-left: 8rpx;
  transition: transform 0.3s ease;
}

.arrow.up {
  transform: rotate(180deg);
}

.analysis-content {
  margin-top: 20rpx;
  background-color: #EBF4FF;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #1E3A8A;
  line-height: 1.6;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(-10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.bottom-spacer {
  height: 240rpx;
}

/* 底部操作区 */
.bottom-action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 30rpx 40rpx 60rpx 40rpx;
  background: linear-gradient(to top, rgba(247, 249, 252, 1) 60%, rgba(247, 249, 252, 0));
  box-sizing: border-box;
}

.primary-btn {
  width: 100% !important;
  height: 110rpx;
  line-height: 110rpx;
  background: linear-gradient(135deg, #EF4444 0%, #B91C1C 100%);
  color: #FFF;
  border-radius: 55rpx;
  font-size: 34rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 32rpx rgba(239, 68, 68, 0.2);
  transition: transform 0.1s;
}

.primary-btn:active {
  transform: scale(0.96);
}

.btn-icon {
  margin-right: 12rpx;
}